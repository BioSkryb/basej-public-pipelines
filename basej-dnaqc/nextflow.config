// ============================================================================
// BASEJ-DNAQC PIPELINE CONFIGURATION
// ============================================================================
// Pipeline: Single-Cell DNA QC Analysis
// Description: Subsample to 2M reads, QC metrics, and CNV-based cluster QC
// Author: Bioskryb
// ============================================================================

manifest {
    name            = "basej-dnaqc"
    description     = "Single-cell DNA QC pipeline with metrics collection and CNV cluster QC"
    homePage        = "https://github.com/BioSkryb/nf-bioskryb-utils/"
    mainScript      = "main.nf"
    version         = '1.0.0'
}

nextflow.enable.dsl=2
nextflow.enable.configProcessNamesValidation = false

// ============================================================================
// LOAD SHARED CONFIGURATIONS
// ============================================================================
includeConfig './conf/genomes.config'
includeConfig './conf/environment.config'

// ============================================================================
// DEFAULT PARAMETERS
// ============================================================================
params {
    // Workflow identification
    // On resume, reuse the original workflow_id to keep output paths stable and idempotent
    resume_workflow_id = null
    workflow_id     = params.resume_workflow_id ?: System.getenv("TOWER_WORKFLOW_ID") ?: "TEST_WORKFLOW_ID"
    biosample_count = "0"
    workspace       = "basej-dnaqc"
    dataset_id      = "test_dataset"
    pipeline_user   = "basejumper"

    // Input/Output
    input_csv              = ""
    outputDir              = "results"

    // Genome and reference
    genome                 = "GRCh38"
    platform               = ""  // Auto-detected from CSV columns: cram → Ultima, read1/read2 → Illumina
    architecture           = "arm"       // Compute architecture: arm (Graviton, default) or x86

    // Pipeline tool selection: 'opensource' (BWA-MEM2 + samtools markdup + Picard) or 'sentieon' (proprietary)
    pipeline_tool          = "opensource"

    // CNV Ginkgo parameters (for GRCh38, GRCm39, ARSUCD2)
    bin_size            = 1000000  // 500000, 1000000, 2000000 options
    min_ploidy          = 1.5
    max_ploidy          = 6
    min_bin_width       = 5
    is_haplotype        = 2

    // Read processing parameters
    seqkit_sample_seed     = 12345
    samtools_seed          = 12345
    n_reads                = 2000000  // Subsample to 2M reads for QC
    read_length            = 50       // Used for Ginkgo reference selection

    // Resource labelling for AWS batch tagging
    pipeline_user                = "basejumper"
    biosample_count              = "0"
    basejumper_organization_uuid = ""
    basejumper_organization_name = ""

    // Reference files (auto-populated from genomes.config)
    reference           = params.genomes[params.genome]['reference']
    bwamem2_reference   = params.genomes[params.genome]['bwamem2_reference']  // BWA-MEM2 index dir (opensource path)
    ref_fasta           = "${params.genomes[params.genome]['reference']}/genome.fa"  // Required for CRAM decoding
    intervals           = params.genomes[params.genome]['base_metrics_intervals']
    ginko_ref_dir       = params.genomes[params.genome]["${params.bin_size}"]["${params.read_length}"]['ginko_ref_dir']
    dbsnp               = params.genomes[params.genome]['dbsnp']
    dbsnp_index         = params.genomes[params.genome]['dbsnp_index']
    mills               = params.genomes[params.genome]['mills']
    mills_index         = params.genomes[params.genome]['mills_index']
    onekg_omni          = params.genomes[params.genome]['onekg_omni']
    onekg_omni_index    = params.genomes[params.genome]['onekg_omni_index']
}

// Set output directory
outputDir = params.outputDir

// ============================================================================
// RESOURCE LABELS
// ============================================================================


// ============================================================================
// PROCESS CONFIGURATION
// Uses queue patterns from conf/modules.config with architecture-aware selection
// ============================================================================
process {

    // Merge multi-lane FASTQs for the same biosample (cat)
    withName: 'MERGE_MULTILANE_FASTQ' {
        container = 'basejumper_ubuntu_24.04_stable'
        errorStrategy = { task.attempt <= 1 ? 'retry' : 'terminate' }
        cpus      = 4
        memory    = { task.attempt <= 1 ? 12.GB : 28.GB }
        time      = 10.h
    }

    // Subsampling process (seqkit — ARM-native, NVMe SSD scratch)
    withName: 'SEQKIT_SAMPLE' {
        container = 'basejumper_seqkit-2.13.0'
        errorStrategy = { task.attempt <= 1 ? 'retry' : 'terminate' }
        cpus      = 4
        memory    = { task.attempt <= 1 ? 12.GB : 28.GB }
        time      = 10.h
    }

    // CRAM subsampling process for Ultima (samtools — ARM-native, NVMe SSD scratch)
    withName: 'SAMTOOLS_SUBSAMPLE_CRAM' {
        container = 'basejumper_samtools-1.23.1'
        cpus      = 2
        memory    = 7.GB
        time      = 10.h
    }

    // Fastp trimming
    withName: 'FASTP_TRIM' {
        container = "quay.io/biocontainers/fastp:0.20.1--h8b12597_0"
        cpus      = { 2 * task.attempt }
        memory    = { 7.GB * task.attempt }
        time      = { 2.h * task.attempt }
    }

    // Combined alignment + dedup + metrics - main compute process (architecture-aware)
    withName: 'SENTIEON_ALIGN_DEDUP_METRICS' {
        container = '597246834581.dkr.ecr.us-east-1.amazonaws.com/basejumper:sentieon-202503-02'
        cpus      = 8
        memory    = 30.GB
        time      = 2.h
    }

    // BWA-MEM2 alignment + samtools sort (BioSkryb image bundles both tools)
    // x86-only container, so always use the x86 spot queue.
    withName: 'BWAMEM2_ALIGN' {
        container      = "basejumper_bwamem2_samtools_2.2.1"
        cpus           = 8
        memory         = 30.GB
        time           = 2.h
    }

    // samtools markdup deduplication + dedup metrics
    // x86-only container, so always use the x86 spot queue.
    withName: 'SAMTOOLS_MARKDUP' {
        container      = "basejumper_samtools-1.23.1"
        cpus           = 4
        memory         = 16.GB
        time           = 2.h
    }

    // Picard metrics suite (alignment, insert size, GC bias, quality yield, mean qual)
    // Plus per-interval coverage via samtools depth + awk (matches Sentieon CoverageMetrics format)
    // Reuses the existing picard_addorreplacegroups container (picard 3.1.x + samtools bundled).
    // x86-only container, so always use the x86 spot queue.
    withName: 'PICARD_METRICS' {
        container      = "basejumper_picard_addorreplacegroups_3.1.2"
        // Retry transient failures (spot reclaim, image-pull/disk hiccups) on a
        // fresh node, then surface real errors instead of silently producing no
        // metrics (which previously cascaded into a confusing QC_PLOTS failure).
        errorStrategy  = { task.attempt <= 2 ? 'retry' : 'terminate' }
        maxRetries     = 2
        cpus           = 4
        memory         = 16.GB
        time           = 2.h
    }

    // Preseq library complexity estimation
    withName: 'PRESEQ' {
        container = "basejumper_preseq_bam2mr_0.1"
        cpus      = 8
        memory    = 32.GB
        time      = 1.h
    }


    // ========================================================================
    // Ginkgo CNV workflow (GINKO_NOPUBLISH) process definitions.
    // ========================================================================

    // Convert BAM to BED (bedtools)
    withName: 'BAM_TO_BED' {
        container = "quay.io/biocontainers/bedtools:2.28.0--hdf88d34_0"
        cpus      = 1
        memory    = 3.GB
        time      = { 2.h * task.attempt }
    }

    // Bin unsorted reads (Ginkgo)
    withName: 'GINKGO_BINUNSORT' {
        container = "basejumper_ginkgo_0.3.1"
        cpus      = 1
        memory    = 3.GB
        time      = 1.h
    }

    // CNV segmentation (Ginkgo, batch)
    withName: 'GINKGO_SEGMENTATION_R' {
        container = "basejumper_ginkgo_0.3.1"
        cpus      = 1
        memory    = 3.GB
        time      = 1.h
    }

    // CNV caller (Ginkgo, batch)
    withName: 'GINKGO_CNV_CALLER' {
        container = "basejumper_ginkgo_0.3.1"
        cpus      = 1
        memory    = 3.GB
        time      = 1.h
    }

    // RDS to flat files (Ginkgo, batch)
    withName: 'GINKO_RDS_TO_FLAT' {
        container = "basejumper_ginkgo_0.3.1"
        cpus      = 1
        memory    = 3.GB
        time      = 1.h
    }

    // Parse Ginkgo outputs (per-sample CNV calls)
    withName: 'GINKO_PARSE_OUTPUTS' {
        container = "basejumper_ginko_parser_0.2.1"
        cpus      = 2
        memory    = 7.GB
        time      = 1.h
    }

    // Parse RDS for CNV metrics summary (AllSample-GinkgoSegmentSummary.txt)
    withName: 'PARSE_RDS_CNV_METRICS' {
        container = "basejumper_ginkgo_0.3.1"
        errorStrategy = 'ignore'
        cpus      = 2
        memory    = 7.GB
        time      = 1.h
    }

    // Ginkgo bin-level CNV to parquet (long format)
    withName: 'GINKGO_BINS_TO_PARQUET' {
        container = "basejumper_custom_parabricks-metrics_1.0.3"
        cpus      = 2
        memory    = 7.GB
        time      = 30.m
    }

    // MultiQC report generation
    withName: 'MULTIQC' {
        container = "quay.io/biocontainers/multiqc:1.33--pyhdfd78af_0"
        errorStrategy = { task.attempt <= 2 ? 'retry' : 'terminate' }
        cpus      = { 2 * task.attempt }
        memory    = { 7.GB * task.attempt }
        time      = 5.h
    }

    // QC_PLOTS - REQUIRED for basej-dnaqc pipeline (override ignore from modules.config)
    withName: 'QC_PLOTS' {
        container   = "basejumper_custom_r_qcplots_0.2.1"
        errorStrategy = { task.attempt <= 2 ? 'retry' : 'terminate' }
        maxRetries = 2
        cpus      = { 2 * task.attempt }
        memory    = { 7.GB * task.attempt }
        time      = 1.h
    }

}

// ============================================================================
// LOAD REPORTING CONFIGURATION
// ============================================================================
includeConfig './conf/reporting.config'
