// ============================================================================
// BASEJ-RNAQC PIPELINE CONFIGURATION
// ============================================================================
// Pipeline: Single-Cell RNA QC Analysis
// Description: FASTQ to STAR alignment, HTSeq quantification, QC metrics, and cluster QC
// Author: Bioskryb
// ============================================================================

manifest {
    name            = "basej-rnaqc"
    description     = "Single-cell RNA QC pipeline with metrics collection and cluster QC"
    homePage        = "https://github.com/BioSkryb/nf-bioskryb-utils/"
    mainScript      = "main.nf"
    version         = '1.0.0'
}

nextflow.enable.dsl=2
nextflow.enable.configProcessNamesValidation = false

// ============================================================================
// LOAD SHARED CONFIGURATIONS
// ============================================================================
includeConfig './conf/genomes.config'
includeConfig './conf/environment.config'
// ============================================================================
// DEFAULT PARAMETERS
// ============================================================================
params {
    // Workflow identification
    // On resume, reuse the original workflow_id to keep output paths stable and idempotent
    resume_workflow_id = null
    workflow_id = params.resume_workflow_id ?: System.getenv("TOWER_WORKFLOW_ID") ?: "TEST_WORKFLOW_ID"

    // Input/Output
    input_csv              = ""
    outputDir              = "results"

    // Genome and reference
    genome                 = "GRCh38"
    platform               = ""  // Auto-detected from CSV columns: cram → Ultima, read1/read2 → Illumina
    architecture           = "arm"       // Compute architecture: arm (Graviton, default) or x86

    // Workspace and dataset (for S3 tagging and output organization)
    workspace              = "demo"
    dataset_id             = "test_dataset"

    // Resource labelling for AWS batch tagging
    pipeline_user                = "basejumper"
    biosample_count              = "0"
    basejumper_organization_uuid = ""
    basejumper_organization_name = ""

    // Read processing parameters
    seqkit_sample_seed     = 12345
    samtools_seed          = 12345
    n_reads                = 2000000  // Subsample to 2M reads for QC

    // Reference files (auto-populated from genomes.config)
    star_index          = params.genomes[params.genome]['star_index']
    gtf                 = params.genomes[params.genome]['gtf_file']
    tx2gene             = params.genomes[params.genome]['tx2gene']
    genebody_ref        = params.genomes[params.genome]['genebody_ref']
    ref_fasta           = "${params.genomes[params.genome]['reference']}/genome.fa"  // Required for CRAM→BAM conversion

    // MultiQC config
    multiqc_config      = "${projectDir}/assets/multiqc_config.yaml"
}

// Set output directory
outputDir = params.outputDir

// ============================================================================
// RESOURCE LABELS
// ============================================================================

// ============================================================================
// PROCESS CONFIGURATION
// ============================================================================
process {

    // Merge multi-lane FASTQs for the same biosample (cat)
    withName: 'MERGE_MULTILANE_FASTQ' {
        container = 'basejumper_ubuntu_24.04_stable'
        errorStrategy = { task.attempt <= 1 ? 'retry' : 'terminate' }
        cpus      = 4
        memory    = { task.attempt <= 1 ? 12.GB : 28.GB }
        time      = 10.h
    }

    // Subsampling process (seqkit — ARM-native, NVMe SSD scratch)
    withName: 'SEQKIT_SAMPLE' {
        container = 'basejumper_seqkit-2.13.0'
        errorStrategy = { task.attempt <= 1 ? 'retry' : 'terminate' }
        cpus      = 4
        memory    = { task.attempt <= 1 ? 12.GB : 28.GB }
        time      = 10.h
    }

    // CRAM subsampling process for Ultima (lightweight, similar to SEQKIT_SAMPLE)
    withName: 'SAMTOOLS_SUBSAMPLE_CRAM' {
        container = "quay.io/biocontainers/samtools:1.21--h50ea8bc_0"
        cpus      = 2
        memory    = 7.GB
        time      = 10.h
    }

    // Fastp trimming
    withName: 'FASTP_TRIM' {
        container = "quay.io/biocontainers/fastp:0.20.1--h8b12597_0"
        cpus      = { 2 * task.attempt }
        memory    = { 7.GB * task.attempt }
        time      = { 2.h * task.attempt }
    }

    // STAR alignment - main compute process
    withName: 'STAR_ALIGN' {
        container = "quay.io/biocontainers/star:2.7.6a--0"
        cpus        = 16
        memory      = 60.GB
        time      = { 6.h * task.attempt }
    }


    // Samtools index and filter primary alignments (includes CRAM→BAM conversion for Ultima)
    withName: 'SAMTOOLS_INDEX_FILTER' {
        container = "quay.io/biocontainers/samtools:1.21--h50ea8bc_0"
        cpus      = 4
        memory    = 14.GB
        time      = { 6.h * task.attempt }
    }

    // Qualimap RNA-seq QC analysis
    withName: 'QUALIMAP_BAMRNA' {
        container = "quay.io/biocontainers/qualimap:2.2.2d--1"
        cpus      = 16
        memory    = 60.GB
        time      = 3.h
    }

    // Parse Qualimap output for genomic proportion metrics
    withName: 'CREATE_QC_REPORT' {
        container = "basejumper_custom_r_nf_rnaseq_0.10"
        cpus      = 2
        memory    = 7.GB
        time      = 1.h
    }

    // HTSeq counting
    withName: 'HTSEQ_COUNTS' {
        container = 'quay.io/biocontainers/htseq:0.13.5--py38h803c66d_1'
        cpus      = 2
        memory    = 7.GB
        time      = { 12.h * task.attempt }
    }

    // HTSeq summary processes - use RNA-seq 0.10 container with htseq_to_gene_df.R script
    withName: 'CREATE_HTSEQ_SUMMARY|MERGE_HTSEQ_SUMMARY' {
        container = "basejumper_custom_r_nf_rnaseq_0.10"
        cpus      = 2
        memory    = 7.GB
        time      = 1.h
    }

    // HTSeq matrix process - use RNA-seq 0.15 container
    withName: 'CREATE_HTSEQ_MATRIX' {
        container = "basejumper_custom_r_qcplots_0.2.3"
        errorStrategy = 'ignore'  // Allow pipeline to continue if matrix creation fails
        cpus      = 2
        memory    = 7.GB
        time      = 1.h
    }

    // PCA/Heatmap plotter - use RNA-seq 0.9 container
    withName: 'PLOTTER_PCAHEATMAP' {
        container = "basejumper_custom_r_nf_rnaseq_0.9"
        errorStrategy = 'ignore'  // Allow pipeline to continue if PCA/heatmap fails (e.g., too few samples)
        cpus      = 2
        memory    = 7.GB
        time      = 1.h
    }

    // RNA_QC_PLOTS - Consolidated mega-process with retry logic
    withName: 'RNA_QC_PLOTS' {
        container   = "basejumper_custom_r_qcplots_0.2.3"
        errorStrategy = { task.attempt <= 2 ? 'retry' : 'terminate' }
        maxRetries = 2
        cpus      = { 2 * task.attempt }
        memory    = { 7.GB * task.attempt }
        time      = 1.h
    }

    // MultiQC report generation
    withName: 'MULTIQC' {
        container = "quay.io/biocontainers/multiqc:1.33--pyhdfd78af_0"
        errorStrategy = { task.attempt <= 2 ? 'retry' : 'terminate' }
        cpus      = { 2 * task.attempt }
        memory    = { 7.GB * task.attempt }
        time      = 5.h
    }

    // Gene body coverage per-sample analysis
    withName: 'GENE_BODY_COVERAGE_RNA' {
        container   = 'basejumper_gene_body_coverage_0.2.1'
        cpus        = 2
        memory      = 7.GB
        time        = { 3.h * task.attempt }
    }

    // Gene body coverage aggregate plot
    withName: 'GENE_BODY_COVERAGE_RNA_PLOT' {
        container   = 'basejumper_gene_body_coverage_0.2.1'
        cpus        = 2
        memory      = 7.GB
        time        = 1.h
    }

}

// ============================================================================
// LOAD REPORTING CONFIGURATION
// ============================================================================
includeConfig './conf/reporting.config'
