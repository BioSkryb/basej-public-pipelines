// ============================================================================
// BASEJ-LINEAGE PIPELINE CONFIGURATION
// ============================================================================
// Matrix-consumer lineage + mutational-signatures pipeline. Merges two of Isai's
// standalone subworkflows:
//   * LINEAGE_FROM_MATRICES        — phylogeny / lineage from NR/NV matrices
//   * MUTSIGNATURES_FROM_MATRICES  — COSMIC signatures from a binary matrix
//
// Params + process withName blocks are mirrored from the two source subworkflow
// nextflow.config files (containers/resources copied for Batch parity).
// ============================================================================

manifest {
    name        = "basej-lineage"
    description = "Matrix-consumer single-cell somatic lineage + mutational-signatures pipeline"
    homePage    = "https://github.com/BioSkryb/nf-bioskryb-utils/"
    mainScript  = "main.nf"
    version     = '1.0.0'
}

nextflow.enable.dsl=2
nextflow.enable.configProcessNamesValidation = false

// ============================================================================
// LOAD SHARED CONFIGURATIONS
// ============================================================================
includeConfig './conf/genomes.config'
includeConfig './conf/environment.config'

// ============================================================================
// DEFAULT PARAMETERS
// ============================================================================
params {
    // ── Workflow identification ──────────────────────────────────────────────
    // On resume, reuse the original workflow_id to keep output paths stable.
    resume_workflow_id = null
    workflow_id     = params.resume_workflow_id ?: System.getenv("TOWER_WORKFLOW_ID") ?: "TEST_WORKFLOW_ID"

    // ── Workspace / project (S3 tagging + output organisation) ───────────────
    workspace       = "demo"
    project         = "test_project"
    outputDir       = "results"

    // Reference genome (labelling / schema validation)
    genome          = "GRCh38"

    // ── Lineage manifest (optional — auto-resolve from somatic connector) ────
    // When provided, the pipeline parses this CSV (header: group,param,path) and
    // populates nr_matrix / nv_matrix / binary_matrix / mandatory_variants_qc_status /
    // input_csv from the rows (single-group assumed). Individual params below still
    // serve as direct overrides or standalone invocation.
    lineage_csv  = null   // S3 URI to lineage_inputs.csv produced by basej-somatic

    // ── Pre-built matrices (REQUIRED unless lineage_csv provided) ─────────────
    // Paired NR/NV matrices (rows = CHROM_POS_REF_ALT, cols = samples). Used as the
    // single 'unfiltered' scheme; NR/NV drive treemut AND variant placement.
    // Use the basej-somatic PlusMandatoryNonEmpty scheme (downstream_inputs bundle), NOT
    // ForPhylogeny: ForPhylogeny is placed in full by the phylogeny step, leaving the
    // variant-placement step empty and skipping the VAF/digital heatmaps.
    nr_matrix    = null   // path to pre-built NR matrix TSV (…PlusMandatoryNonEmpty.tsv)
    nv_matrix    = null   // path to paired NV matrix TSV (…PlusMandatoryNonEmpty.tsv)

    // Pre-binarized variant × sample matrix (0/1). Required for the mutsig branch;
    // when null the mutational-signature branch is skipped.
    binary_matrix = null

    // ── genotype_bin (OPTIONAL, "Option D") ──────────────────────────────────
    // Pre-built binarized genotype matrix (0/0.5/1). When set, SEQUOIA_PHYLOGENY_*
    // skips VAF discretization. null = discretize VAF from NR/NV.
    genotype_bin = null

    // ── VCF input (REQUIRED, exactly one) — for per-sample genotype tables ────
    // Option A: CSV with header row: biosampleName,vcf,vcf_index.
    input_csv    = ""
    // Option B: directory containing *_somatic_annotated.vcf.gz + .tbi pairs.
    vcf_dir      = ""

    // ── Cohort ───────────────────────────────────────────────────────────────
    cohort_id      = "cohort"

    // ── Sample metadata ────────────────────────────────────────────────────────
    gender = "female"   // passed to all SEQUOIA_PHYLOGENY_* and SEQUOIA_VARIANT_PLACEMENT_*

    // ── SEQUOIA phylogeny ──────────────────────────────────────────────────────
    // Comma-separated: snv, indel, both, and/or all (all = run all three).
    sequoia_phylogeny_mode            = "snv,indel,both"
    sequoia_vaf_absent                = 0.1
    sequoia_vaf_present               = 0.3
    sequoia_tree_mut_pval             = 0.01
    sequoia_keep_ancestral            = false
    sequoia_genotype_conv_prob        = false
    sequoia_min_pval_for_true_somatic = 0.05
    sequoia_min_variant_reads_shared  = 2
    sequoia_min_vaf_shared            = 2
    sequoia_create_multi_tree         = true
    sequoia_mpboot_path               = "/usr/local/bin/"
    sequoia_mpboot_bootstrap          = 1000   // MPBoot -bb replicates (must be >= 1000)

    // POSTPROCESS_SEQUOIA_DRAWVAFHEAT_TREE_* heatmap options
    postprocess_heatmap_y_axis_text_size = 5
    plot_tips                            = false

    // Optional mandatory_variants_qc_status_${group}.tsv. When set, failing mandatory
    // variants are removed from the VAF/digital heatmaps. null = show all placed.
    mandatory_variants_qc_status = null

    // ── SigProfilerAssignment (mutsig branch) ────────────────────────────────
    sig_genome_build                      = "GRCh38"
    sig_context_type                      = "96"
    sig_exome                             = false
    sig_export_probabilities              = true
    sig_export_probabilities_per_mutation = true

    // ── Additional signature pipelines ────────────────────────────────────────
    // MuSiCaL (Park lab) — COSMIC SBS likelihood-bidirectional refitting.
    musical_enabled                 = true
    // SigDyn (Goncalves lab) — strict best-subset COSMIC fitting + dynamics stats.
    sigdyn_enabled                  = true
    // musicatk (Campbell lab) — de novo NMF/LDA. Requires R >= 4.4.0; disabled by default.
    musicatk_enabled                = false
    musicatk_k_denovo               = 5
}

// Set output directory for reporting.config
outputDir = params.outputDir

// ============================================================================
// PROCESS CONFIGURATION
// Containers + queue/cpus/memory/time copied from the two source subworkflow
// nextflow.config files (Batch parity). resourceLabels added per basej convention.
// ============================================================================
process {

    // ────────────────────────────────────────────────────────────────────────
    // LINEAGE BRANCH  (from lineage_from_matrices/nextflow.config)
    // ────────────────────────────────────────────────────────────────────────
    withName: 'GENOTYPE_TABLE_FROM_ANNOTATED_VCF' {
        container     = "quay.io/biocontainers/bcftools:1.14--h88f3f91_0"
        errorStrategy = 'retry'
        cpus          = 1
        memory        = 4.GB
        time          = 4.h
    }

    withName: 'SEQUOIA_PHYLOGENY_SNV' {
        container     = "basejumper_custom_snp_somatic_filter_sequoia_feb2026"
        errorStrategy = 'finish'
        maxRetries    = 0
        cpus          = 2
        memory        = 7.GB
        time          = 48.h
    }

    withName: 'SEQUOIA_PHYLOGENY_INDEL' {
        container     = "basejumper_custom_snp_somatic_filter_sequoia_feb2026"
        errorStrategy = 'finish'
        maxRetries    = 0
        cpus          = 2
        memory        = 7.GB
        time          = 48.h
    }

    withName: 'SEQUOIA_PHYLOGENY_BOTH' {
        container     = "basejumper_custom_snp_somatic_filter_sequoia_feb2026"
        errorStrategy = 'finish'
        maxRetries    = 0
        cpus          = 2
        memory        = 7.GB
        time          = 48.h
    }

    withName: 'SEQUOIA_VARIANT_PLACEMENT_SNV' {
        container     = "basejumper_custom_snp_somatic_filter_sequoia_feb2026"
        errorStrategy = { task.attempt <= 2 ? 'retry' : 'finish' }
        cpus          = 4
        memory        = 15.GB
        time          = 24.h
    }

    withName: 'SEQUOIA_VARIANT_PLACEMENT_INDEL' {
        container     = "basejumper_custom_snp_somatic_filter_sequoia_feb2026"
        errorStrategy = { task.attempt <= 2 ? 'retry' : 'finish' }
        cpus          = 4
        memory        = 15.GB
        time          = 24.h
    }

    withName: 'SEQUOIA_VARIANT_PLACEMENT_BOTH' {
        container     = "basejumper_custom_snp_somatic_filter_sequoia_feb2026"
        errorStrategy = { task.attempt <= 2 ? 'retry' : 'finish' }
        cpus          = 4
        memory        = 15.GB
        time          = 24.h
    }

    withName: 'POSTPROCESS_SEQUOIA_DRAWVAFHEAT_TREE_SNV' {
        container     = "basejumper_custom_snp_somatic_filter_sequoia_feb2026"
        errorStrategy = { task.attempt <= 2 ? 'retry' : 'finish' }
        cpus          = 8
        memory        = 30.GB
        time          = 48.h
    }

    withName: 'POSTPROCESS_SEQUOIA_DRAWVAFHEAT_TREE_INDEL' {
        container     = "basejumper_custom_snp_somatic_filter_sequoia_feb2026"
        errorStrategy = { task.attempt <= 2 ? 'retry' : 'finish' }
        cpus          = 8
        memory        = 30.GB
        time          = 48.h
    }

    withName: 'POSTPROCESS_SEQUOIA_DRAWVAFHEAT_TREE_BOTH' {
        container     = "basejumper_custom_snp_somatic_filter_sequoia_feb2026"
        errorStrategy = { task.attempt <= 2 ? 'retry' : 'finish' }
        cpus          = 8
        memory        = 30.GB
        time          = 48.h
    }

    // GATHER has no withName in the source lineage config; needs the feb2026 image
    // (poppler/pdftoppm) to render figure PNGs. Lightweight resources.
    withName: 'GATHER_LINEAGE_POSTPROCESS_ARTIFACTS' {
        container     = "basejumper_custom_snp_somatic_filter_sequoia_feb2026"
        errorStrategy = { task.attempt <= 2 ? 'retry' : 'ignore' }
        cpus          = 2
        memory        = 7.GB
        time          = 4.h
    }

    // ────────────────────────────────────────────────────────────────────────
    // MUTSIGNATURES BRANCH  (from mutsignatures_from_matrices/nextflow.config)
    // ────────────────────────────────────────────────────────────────────────
    withName: 'EXPORT_MUTSIG_SOMATIC_VARIANT_TABLE_FROM_BINARY_MATRIX' {
        container     = "basejumper_custom_snp_somatic_filter_sequoia_feb2026"
        errorStrategy = 'retry'
        cpus          = 2
        memory        = 7.GB
        time          = 2.h
    }

    withName: 'COMPUTE_MUTSIG_COVERAGE_FROM_VARIANT_TABLE' {
        container     = "basejumper_custom_snp_somatic_filter_sequoia_feb2026"
        errorStrategy = 'retry'
        cpus          = 1
        memory        = 2.GB
        time          = 1.h
    }

    withName: 'GATHER_MUTSIG_ARTIFACTS' {
        container     = "basejumper_custom_snp_somatic_filter_sequoia_feb2026"
        errorStrategy = 'retry'
        cpus          = 1
        memory        = 2.GB
        time          = 30.m
    }

    withName: 'SIGPROFILER_MATRIX_GENERATOR_FROM_MUTSIG_SOMATIC_VARIANT_TABLES' {
        container     = "basejumper_sigprofiler-0.1.0"
        errorStrategy = 'retry'
        cpus          = 2
        memory        = 7.GB
        time          = 24.h
    }

    // Base name + SBS/DBS/ID aliases (SIGPROFILER_ASSIGNMENT_FROM_MATRIX).
    withName: 'SIGPROFILER_ASSIGNMENT_FROM_MATRIX|SIGPROFILER_ASSIGNMENT_SBS|SIGPROFILER_ASSIGNMENT_DBS|SIGPROFILER_ASSIGNMENT_ID' {
        container     = "basejumper_sigprofiler-0.1.0"
        errorStrategy = 'retry'
        cpus          = 2
        memory        = 7.GB
        time          = 24.h
    }

    // Base name + SBS/DBS/ID aliases (MERGE_SIGNATURE_ACTIVITIES).
    withName: 'MERGE_SIGNATURE_ACTIVITIES|MERGE_ACTIVITIES_SBS|MERGE_ACTIVITIES_DBS|MERGE_ACTIVITIES_ID' {
        container     = "basejumper_sigprofiler-0.1.0"
        errorStrategy = 'retry'
        cpus          = 1
        memory        = 4.GB
        time          = 1.h
    }

    // Base name + SBS/DBS/ID aliases (PLOT_MATRIX_SIGNATURE_BARGRAPHS).
    withName: 'PLOT_MATRIX_SIGNATURE_BARGRAPHS|PLOT_BARGRAPHS_SBS|PLOT_BARGRAPHS_DBS|PLOT_BARGRAPHS_ID' {
        container     = "basejumper_custom_snp_somatic_filter_sequoia_feb2026"
        errorStrategy = 'retry'
        cpus          = 2
        memory        = 7.GB
        time          = 2.h
    }

    withName: 'MUSICAL_SIGNATURE_ANALYSIS' {
        container     = "basejumper_custom_snp_somatic_filter_sequoia_feb2026"
        errorStrategy = 'retry'
        cpus          = 4
        memory        = 15.GB
        time          = 4.h
    }

    withName: 'SIGDYN_SIGNATURE_ANALYSIS' {
        container     = "basejumper_custom_snp_somatic_filter_sequoia_feb2026"
        errorStrategy = 'retry'
        cpus          = 4
        memory        = 15.GB
        time          = 4.h
    }

    withName: 'MUSICATK_SIGNATURE_ANALYSIS' {
        container     = "basejumper_custom_snp_somatic_filter_sequoia_feb2026"
        errorStrategy = 'retry'
        cpus          = 4
        memory        = 28.GB
        time          = 6.h
    }

    withName: 'PLOT_COMPARATIVE_SIGNATURE_ACTIVITIES' {
        container     = "basejumper_custom_snp_somatic_filter_sequoia_feb2026"
        errorStrategy = { task.attempt <= 2 ? 'retry' : 'finish' }
        cpus          = 1
        memory        = 4.GB
        time          = 1.h
    }

    // Empty-matrix gating (inline in the mutsig subworkflow; feb2026 image).
    withName: 'CHECK_MATRIX_NON_EMPTY_DBS|CHECK_MATRIX_NON_EMPTY_ID' {
        container     = "basejumper_custom_snp_somatic_filter_sequoia_feb2026"
        errorStrategy = { task.attempt <= 2 ? 'retry' : 'ignore' }
        cpus          = 1
        memory        = 2.GB
        time          = 10.m
    }

    // ────────────────────────────────────────────────────────────────────────
    // MULTIQC summary report
    // ────────────────────────────────────────────────────────────────────────
    withName: 'MULTIQC_LINEAGE' {
        container     = "quay.io/biocontainers/multiqc:1.33--pyhdfd78af_0"
        errorStrategy = { task.attempt <= 2 ? 'retry' : 'terminate' }
        cpus          = { 2 * task.attempt }
        memory        = { 7.GB * task.attempt }
        time          = 5.h
    }

}

// ============================================================================
// LOAD REPORTING CONFIGURATION
// ============================================================================
includeConfig './conf/reporting.config'
