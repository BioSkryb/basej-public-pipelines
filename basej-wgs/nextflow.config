// ============================================================================
// BASEJ-WGS PIPELINE CONFIGURATION
// ============================================================================
// Pipeline: Single-Cell WGS/WES QC Analysis
// Description: Alignment, deduplication, BQSR, and QC metrics collection.
//              Supports WGS and WES modes via params.mode.
// Author: Bioskryb
// ============================================================================

manifest {
    name            = "basej-wgsqc"
    description     = "Single-cell WGS/WES QC pipeline with alignment and metrics collection"
    homePage        = "https://github.com/BioSkryb/nf-bioskryb-utils/"
    mainScript      = "main.nf"
    version         = '1.0.0'
}

nextflow.enable.dsl=2
nextflow.enable.configProcessNamesValidation = false

// ============================================================================
// LOAD SHARED CONFIGURATIONS
// ============================================================================
includeConfig './conf/genomes.config'
includeConfig './conf/environment.config'

// ============================================================================
// DEFAULT PARAMETERS
// ============================================================================
params {
    // Workflow identification
    // On resume, reuse the original workflow_id to keep output paths stable and idempotent
    resume_workflow_id = null
    workflow_id = params.resume_workflow_id ?: System.getenv("TOWER_WORKFLOW_ID") ?: "TEST_WORKFLOW_ID"

    // Input/Output
    input_csv              = ""
    outputDir              = "results"

    // Genome and reference
    genome                 = "GRCh38"
    platform               = "Illumina"  // Sequencing platform: Illumina, Ultima, Element
    architecture           = "x86"       // Compute architecture: arm (Graviton, default) or x86

    // Pipeline mode
    mode                   = "wgs"       // wgs or exome
    exome_panel            = "xGen Exome Hyb Panel v2"
    // "xGen Exome Hyb Panel v2", "TruSight One", "TWIST", "Agilent Clinical Exome", "Twist Exome 2.0", "xGen Pan-Cancer Hybridization Panel", "Twist Alliance CNTG Hereditary Oncology Panel"

    // Pipeline tool selection: 'sentieon' (proprietary, default) or 'opensource'
    // (BWA-MEM2 + samtools markdup + Picard, x86-only — bwa-mem2 has no ARM build)
    pipeline_tool          = "opensource"

    // Workspace and dataset (for S3 tagging and output organization)
    workspace              = "demo"
    dataset_id             = "test_dataset"

    // Read subsampling (disabled by default for WGS; enable for testing)
    skip_subsampling       = false
    max_total_reads        = 1_000_000_000
    seqkit_sample_seed     = 12345
    samtools_seed          = 12345

    // Coverage-targeted subsampling for Ultima/CRAM. When set, every CRAM
    // biosample is subsampled to this single target coverage and renamed
    // `{biosample}_cov{NN}x`. Requires `custom_mean_coverage` per CRAM row
    // in input_csv. One target per pipeline run keeps each launch's cost
    // structure identical to a standard basej-wgs run; MCP queues N
    // launches when N coverage tiers are needed. null = no subsampling.
    coverage_target        = null

    // Resource labelling for AWS batch tagging
    pipeline_user                = "basejumper"
    biosample_count              = "0"
    basejumper_organization_uuid = ""
    basejumper_organization_name = ""

    // Reference files (auto-populated from genomes.config)
    reference              = params.genomes[params.genome]['reference']
    base_metrics_intervals = params.genomes[params.genome]['base_metrics_intervals']
    bwamem2_reference      = params.genomes[params.genome]['bwamem2_reference']  // BWA-MEM2 index dir (opensource path)
}

// Set output directory
outputDir = params.outputDir

// ============================================================================
// RESOURCE LABELS
// ============================================================================

// ============================================================================
// PROCESS CONFIGURATION
// ============================================================================
process {

    // Merge multi-lane FASTQs for the same biosample (cat)
    withName: 'MERGE_MULTILANE_FASTQ' {
        container = 'basejumper_ubuntu_24.04_stable'
        errorStrategy = { task.attempt <= 1 ? 'retry' : 'terminate' }
        cpus      = 4
        memory    = 12.GB
        time      = 10.h
    }

    // Optional subsampling: pigz|gzip count + seqkit sample (arm: Graviton NVMe; x86: amd64 image)
    withName: 'SEQKIT_SAMPLE' {
        container = 'basejumper_seqkit-2.13.0'
        cpus      = 4
        memory    = 28.GB
        time      = 24.h
    }

    // CRAM subsampling for Ultima platform (samtools — ARM-native, NVMe SSD scratch)
    withName: 'SAMTOOLS_SUBSAMPLE_CRAM' {
        container = 'basejumper_samtools-1.23.1'
        cpus      = 2
        memory    = 7.GB
        time      = 10.h
    }

    // CRAM subsampling driven by a pre-computed proportion (coverage fan-out).
    // Same container/queue family as SAMTOOLS_SUBSAMPLE_CRAM but typically
    // runs once per (biosample × coverage_target) so concurrency is higher.
    // Uses on-demand directly — these tasks run 1-2h on high-coverage WGS
    // CRAMs and spot reclamation causes repeated failures.
    withName: 'SAMTOOLS_SUBSAMPLE_CRAM_PROPORTION' {
        container = 'basejumper_samtools-1.23.1'
        errorStrategy = { task.attempt <= 1 ? 'retry' : 'ignore' }
        maxRetries    = 1
        cpus      = 4
        memory    = 15.GB
        time      = 10.h
    }

    // Alignment + Dedup + BQSR - main compute process (architecture-aware)
    withName: 'SENTIEON_ALIGN_DEDUP' {
        errorStrategy = { task.attempt <= 1 ? 'retry' : 'ignore' }
        maxRetries    = 1
        container = '597246834581.dkr.ecr.us-east-1.amazonaws.com/basejumper:sentieon-202503-02'
        cpus      = 64
        memory    = 123.GB
        time      = 12.h
    }

    // QC metrics collection for pre-aligned CRAM input (e.g. Ultima)
    // Mirrors SENTIEON_DRIVER_METRICS — same Sentieon driver, same algos,
    // just no dedup re-run since Ultima `demux` already marks duplicates.
    withName: 'SENTIEON_METRICS_CRAM' {
        errorStrategy = { task.attempt <= 1 ? 'retry' : 'ignore' }
        maxRetries    = 1
        container = '597246834581.dkr.ecr.us-east-1.amazonaws.com/basejumper:sentieon-202503-02'
        cpus      = { params.mode == 'exome' ? 8  : 64 }
        memory    = { params.mode == 'exome' ? 15.GB : 123.GB }
        time      = { params.mode == 'exome' ? 2.h : 5.h }
    }

    // QC metrics collection (architecture-aware)
    withName: 'SENTIEON_DRIVER_METRICS' {
        errorStrategy = { task.attempt <= 1 ? 'retry' : 'ignore' }
        maxRetries    = 1
        container = '597246834581.dkr.ecr.us-east-1.amazonaws.com/basejumper:sentieon-202503-02'
        cpus      = { params.mode == 'exome' ? 8  : 64 }
        memory    = { params.mode == 'exome' ? 15.GB : 123.GB }
        time      = { params.mode == 'exome' ? 2.h : 5.h }
    }

    // ---- Open-source path processes (x86-only; bwa-mem2 has no ARM build) ----

    // BWAMEM2_ALIGN_DEDUP_METRICS: consolidated align + markdup + Picard metrics.
    // Single heavy process (no inter-process BAM staging), sized like the
    // Sentieon WGS path. x86-only container, intense queue (large-spot tops
    // out at 16cpu/64gb so it cannot host this).
    withName: 'BWAMEM2_ALIGN_DEDUP_METRICS' {
        errorStrategy = { task.attempt <= 1 ? 'retry' : 'ignore' }
        maxRetries    = 1
        container     = "basejumper_bwamem2_samtools_picard_1.0.0"
        cpus      = 64
        memory    = 120.GB
        time      = 24.h
    }

    // PICARD_METRICS_CRAM: open-source metrics-only for pre-aligned CRAM (Ultima).
    // No alignment, so lighter than the FASTQ process. Mode-aware sizing mirrors
    // SENTIEON_METRICS_CRAM (exome: large; wgs: intense). x86-only container.
    withName: 'PICARD_METRICS_CRAM' {
        errorStrategy = { task.attempt <= 1 ? 'retry' : 'ignore' }
        maxRetries    = 1
        container     = "basejumper_picard_addorreplacegroups_3.1.2"
        cpus      = { params.mode == 'exome' ? 8  : 16 }
        memory    = { params.mode == 'exome' ? 30.GB : 60.GB }
        time      = { params.mode == 'exome' ? 2.h : 5.h }
    }

    // Picard HS metrics - exome mode only
    withName: 'PICARD_COLLECTHSMETRICS' {
        container = "quay.io/biocontainers/picard:3.0.0--hdfd78af_0"
        cpus      = 4
        memory    = 8.GB
        time      = 5.h
    }

    // Metrics parsing + Parquet output
    withName: 'WGS_QC_METRICS_TO_PARQUET' {
        container = "basejumper_custom_parabricks-metrics_1.0.3"
        cpus      = 2
        memory    = 7.GB
        time      = 1.h
    }

    // QC Plots + final parquet rewrite with QC status
    withName: 'WGS_QC_PLOTS' {
        container = "basejumper_custom_r_qcplots_0.2.1"
        cpus      = 2
        memory    = 7.GB
        time      = 1.h
    }

    // MultiQC report generation
    withName: 'MULTIQC' {
        container = "quay.io/biocontainers/multiqc:1.33--pyhdfd78af_0"
        errorStrategy = { task.attempt <= 2 ? 'retry' : 'terminate' }
        cpus      = { 2 * task.attempt }
        memory    = { 7.GB * task.attempt }
        time      = 5.h
    }

}

// ============================================================================
// LOAD REPORTING CONFIGURATION
// ============================================================================
includeConfig './conf/reporting.config'
