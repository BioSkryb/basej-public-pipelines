nextflow_pipeline {

    name "Test Workflow main.nf"
    script "main.nf"

    test("wgs_GRCh38_test") {
        tag "GRCh38"
        when {
            params {
                outputDir              = "${outputDir}"
                workspace              = "demo"
                workflow_id            = "test_wgs_GRCh38"
                input_csv              = "$baseDir/tests/data/inputs/nftest_input.csv"
                max_memory             = "24.GB"
                max_cpus               = "8"
                architecture           = "x86"
                genome                 = "GRCh38"
                mode                   = "wgs"
                skip_subsampling       = true
                pipeline_tool          = "opensource"
            }
        }

        then {
            assertAll(

                { assert workflow.success },

                { assert path("${outputDir}/workflow_outputs/demo/test_wgs_GRCh38/reports/multiqc_report.html").exists() },

                // Check wgsqc_all_metrics.tsv - full-schema TSV for nf-test validation
                {
                    def f = path("${outputDir}/workflow_outputs/demo/test_wgs_GRCh38/metrics/wgsqc_metrics/wgsqc_all_metrics.tsv")
                    assert f.exists()
                    def lines  = f.readLines()
                    def header = lines[0].split('\t').toList()

                    // Required columns must be present
                    [
                        'qc_score', 'qc_status', 'total_reads', 'pct_duplication',
                        'mean_coverage', 'pct_chimeras',
                        'pf_aligned_bases', 'pf_hq_aligned_reads', 'pf_hq_aligned_bases',
                        'pf_hq_aligned_q20_bases', 'pf_hq_error_rate', 'pct_adapter',
                        'insert_median', 'insert_mad', 'insert_min', 'insert_max',
                        'gc_nc_0_19', 'gc_nc_20_39', 'gc_nc_40_59', 'gc_nc_60_79', 'gc_nc_80_100',
                        'median_coverage', 'mad_coverage',
                        'pct_1x', 'pct_5x', 'pct_10x',
                        'pct_exc_mapq', 'pct_exc_dupe', 'pct_exc_baseq', 'pct_exc_total',
                    ].each { col ->
                        assert header.contains(col) : "Missing column: ${col}"
                    }

                    def idx = { col -> header.indexOf(col) }

                    // Helper: parse a numeric cell, skip if blank/None
                    def dbl = { v -> (v && v != 'None' && !v.isEmpty()) ? v.toDouble() : null }
                    def lng = { v -> (v && v != 'None' && !v.isEmpty()) ? v.toLong()   : null }

                    // Expected values from opensource WGS test run (skip_subsampling=true, ~1M reads per sample)
                    def expected = [
                        'ResolveOMEv2.0-384-WGS-B4':  [total_reads: 2000367, qc_status: 'FAIL', qc_score: 2],
                        'ResolveOMEv2.0-384-WGS-D3':  [total_reads: 1999493, qc_status: 'FAIL', qc_score: 2],
                    ]

                    assert lines.size() - 1 == expected.size() : "Expected ${expected.size()} samples, got ${lines.size() - 1}"

                    for (int i = 1; i < lines.size(); i++) {
                        def cols   = lines[i].split('\t', -1)
                        def sample = cols[0]
                        def exp    = expected[sample]
                        assert exp != null : "Unexpected sample in wgsqc_all_metrics.tsv: ${sample}"

                        assert cols[idx('total_reads')].trim().toLong()  == exp.total_reads : "total_reads mismatch for ${sample}"
                        assert cols[idx('qc_status')].trim()             == exp.qc_status   : "qc_status mismatch for ${sample}"
                        assert cols[idx('qc_score')].trim().toDouble().intValue() == exp.qc_score : "qc_score mismatch for ${sample}"

                        // mean_coverage: >0 for WGS (observed ~0.08x at subsampled depth)
                        def meanCov = dbl(cols[idx('mean_coverage')].trim())
                        if (meanCov != null) assert meanCov > 0 && meanCov < 1.0 : "mean_coverage out of range for ${sample}: ${meanCov}"

                        // pct_duplication: very low at this depth
                        def pctDup = dbl(cols[idx('pct_duplication')].trim())
                        if (pctDup != null) assert pctDup >= 0.0 && pctDup <= 0.001 : "pct_duplication out of range for ${sample}: ${pctDup}"

                        // pct_chimeras: observed 0.06-0.07
                        def chimeras = dbl(cols[idx('pct_chimeras')].trim())
                        if (chimeras != null) assert chimeras >= 0.03 && chimeras <= 0.15 : "pct_chimeras out of range for ${sample}: ${chimeras}"

                        // pct_1x: observed ~0.08 at subsampled depth
                        def pct1x = dbl(cols[idx('pct_1x')].trim())
                        if (pct1x != null) assert pct1x >= 0.04 && pct1x <= 0.15 : "pct_1x out of range for ${sample}: ${pct1x}"

                        // pct_5x and above: very small at subsampled depth
                        ['pct_5x', 'pct_10x'].each { col ->
                            def v = dbl(cols[idx(col)].trim())
                            if (v != null) assert v >= 0.0 && v < 0.005 : "${col} out of range for ${sample}: ${v}"
                        }

                        // GC normalised coverage — sanity range checks
                        def gcNc4059 = dbl(cols[idx('gc_nc_40_59')].trim())
                        if (gcNc4059 != null) assert gcNc4059 >= 0.5 && gcNc4059 <= 1.5 : "gc_nc_40_59 out of range for ${sample}: ${gcNc4059}"

                        // Insert size — observed: median ~295-385
                        def insMedian = dbl(cols[idx('insert_median')].trim())
                        if (insMedian != null) assert insMedian >= 200.0 && insMedian <= 500.0 : "insert_median out of range for ${sample}: ${insMedian}"
                    }
                },

                // Verify wgsqc_summary parquet files exist for all samples
                {
                    assert path("${outputDir}/tables/wgsqc_summary/workspace=demo/workflow_id=test_wgs_GRCh38/biosample=ResolveOMEv2.0-384-WGS-B4/output.parquet").exists()
                    assert path("${outputDir}/tables/wgsqc_summary/workspace=demo/workflow_id=test_wgs_GRCh38/biosample=ResolveOMEv2.0-384-WGS-D3/output.parquet").exists()
                },

                // Verify QC plot was generated
                { assert path("${outputDir}/workflow_outputs/demo/test_wgs_GRCh38/qc_plots/qc_wgs.pdf").exists() }
            )
        }
    }

}
