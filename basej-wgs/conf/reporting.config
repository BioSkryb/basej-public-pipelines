// ============================================================================
// REPORTING CONFIGURATION
// ============================================================================
// Timeline, report, trace, and DAG output settings
// ============================================================================


    
timeline {
    enabled = true
    file    = "${params.outputDir}/workflow_outputs/${params.workspace}/${params.workflow_id}/execution_info/execution_timeline.html"
    overwrite = true
}
report {
    enabled = true
    file    = "${params.outputDir}/workflow_outputs/${params.workspace}/${params.workflow_id}/execution_info/execution_report.html"
    overwrite = true
}
trace {
    enabled = true
    file    = "${params.outputDir}/workflow_outputs/${params.workspace}/${params.workflow_id}/execution_info/execution_trace.txt"
    overwrite = true
}
dag {
    enabled = false
    file    = "${params.outputDir}/workflow_outputs/${params.workspace}/${params.workflow_id}/execution_info/pipeline_dag.svg"
    overwrite = true
}
