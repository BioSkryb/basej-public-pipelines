// ============================================================================
// BASEJ-GOOGLE-DEEPVARIANT PIPELINE CONFIGURATION
// ============================================================================
// Pipeline: Google DeepVariant variant calling (BAM/CRAM -> VCF)
// Description: SNV/indel calling using Google DeepVariant with a BioSkryb
//              custom-trained model that corrects PTA artifacts. Three-stage
//              flow: make_examples / call_variants / postprocess_variants.
//              Runs after basej-wgs.
// Author: Bioskryb
// ============================================================================

manifest {
    name        = "basej-google-deepvariant"
    description = "SNV/indel calling from BAM/CRAM to VCF using Google DeepVariant with a BioSkryb custom-trained model that corrects PTA artifacts. CRAM is read natively by DeepVariant (no conversion needed)."
    homePage    = "https://github.com/BioSkryb/nf-bioskryb-utils/"
    mainScript  = "main.nf"
    version     = '1.0.0'
}

nextflow.enable.dsl=2
nextflow.enable.configProcessNamesValidation = false

// ============================================================================
// LOAD SHARED CONFIGURATIONS
// ============================================================================
includeConfig './conf/genomes.config'
includeConfig './conf/environment.config'
// NOTE: conf/modules.config is intentionally NOT included. This pipeline
// defines all withName blocks below so resource sizing stays local and
// won't be silently shadowed by changes in the shared modules.config.

// ============================================================================
// DEFAULT PARAMETERS
// ============================================================================
params {
    // Workflow identification
    // On resume, reuse the original workflow_id to keep output paths stable and idempotent
    resume_workflow_id = null
    workflow_id     = params.resume_workflow_id ?: System.getenv("TOWER_WORKFLOW_ID") ?: "TEST_WORKFLOW_ID"

    // Input/Output
    input_csv       = ""
    outputDir       = "results"
    timestamp       = ""

    // Genome and reference
    genome          = "GRCh38"
    mode            = "wgs"        // wgs | exome  (exome enables --regions)
    platform        = "Illumina"   // Illumina | Ultima | Element
    architecture    = "arm"        // arm (Graviton, default) or x86

    // Workspace and project (S3 tagging + output organisation)
    workspace       = "demo"
    project         = "test_project"

    // -------------------------------------------------------------------------
    // DeepVariant inputs (auto-populated from genomes.config; overridable)
    // -------------------------------------------------------------------------
    reference         = params.genomes[params.genome]['reference']
    deepvariant_model = params.genomes[params.genome]['bioskrybv1']['model']
    population_vcfs   = params.genomes[params.genome]['bioskrybv1']['population_vcfs']

    // Filename of the .ckpt inside --deepvariant_model
    checkpoint_filename = 'sc_af.model.ckpt'

    // Optional BED to restrict calling (used when mode == 'exome')
    regions           = ""

    // -------------------------------------------------------------------------
    // DeepVariant tunables
    // -------------------------------------------------------------------------
    deepvariant_version       = '1.8.0'
    call_variants_batch_size  = 1024

    // Emit a gVCF alongside the VCF (DeepVariant --gvcf / --gvcf_outfile).
    // Off by default to preserve existing behaviour and avoid the extra
    // make_examples gVCF tfrecord output on runs that don't need it.
    make_gvcf                 = false
}

// Set output directory for reporting.config
outputDir = params.outputDir

// ============================================================================
// RESOURCE LABELS
// ============================================================================
// Defined locally so this pipeline doesn't depend on conf/modules.config.
// The underlying params.* defaults come from conf/environment.config.

// ============================================================================
// PROCESS CONFIGURATION
// ============================================================================
process {

    // ---------------------------------------------------------------------
    // CRAM_TO_BAM — REMOVED: DeepVariant natively reads CRAM via htslib
    // (--ref decodes CRAM automatically since DV v0.9.0). No conversion
    // step is needed. The process config block is retained commented-out
    // for reference during the transition period.
    // ---------------------------------------------------------------------
    // withName: 'CRAM_TO_BAM' { ... }  // REMOVED — no longer used

    // ---------------------------------------------------------------------
    // DeepVariant — make_examples (CPU, sharded across task.cpus)
    // Accepts BAM or CRAM natively. CRAM is decoded using the reference
    // passed via --ref (same reference already staged for variant calling).
    // Exome targets a smaller compute footprint since calling is restricted
    // to the regions BED (typically <1% of genome).
    // ---------------------------------------------------------------------
    withName: 'DEEPVARIANT_MAKE_EXAMPLES_ONLY' {
        container     = "google/deepvariant:${params.deepvariant_version}"
        errorStrategy = { task.attempt <= 1 ? 'retry' : 'ignore' }
        maxRetries    = 1
        maxForks      = 20
        // On-demand from attempt 1 (wgs) for reliability — spot interruptions
        // here were forcing retries and adding latency on high-coverage runs.
        cpus          = { params.mode == 'exome' ? 8     : 62      }
        memory        = { params.mode == 'exome' ? 30.GB : 246.GB  }
        time          = { params.mode == 'exome' ? 1.h   : 24.h    }
    }

    // ---------------------------------------------------------------------
    // DeepVariant — call_variants (GPU). Already lean (8 cpu / 30 GB / 1 GPU).
    // GPU queues are on-demand only.
    // ---------------------------------------------------------------------
    withName: 'DEEPVARIANT_CALL_VARIANTS' {
        container        = "google/deepvariant:${params.deepvariant_version}-gpu"
        errorStrategy    = 'ignore'
        maxRetries       = 0
        containerOptions = '--gpus all'
        accelerator      = 1
        cpus             = 8
        memory           = 30.GB
        time             = { params.mode == 'exome' ? 1.h : 24.h }
    }

    // ---------------------------------------------------------------------
    // DeepVariant — postprocess_variants (CPU)
    // postprocess_variants' final merge/VCF-write phase holds the full sorted
    // candidate set in memory. On high-coverage PTA samples that set is tens
    // of millions of records; the previous 8 cpu / 30 GB profile exhausted
    // memory/scratch and HUNG indefinitely during the merge (observed ~1h40m
    // of zero progress before the run was cancelled). Production runs the same
    // samples on intense-ondemand (62 cpu / 246 GB) and finish in ~7 min — the
    // 246 GB headroom is what prevents the stall, not the cpu count. Use the
    // on-demand intense profile for wgs; exome stays small.
    // ---------------------------------------------------------------------
    withName: 'DEEPVARIANT_POSTPROCESS' {
        container     = "google/deepvariant:${params.deepvariant_version}"
        errorStrategy = { task.attempt <= 1 ? 'retry' : 'ignore' }
        maxRetries    = 1
        cpus          = { params.mode == 'exome' ? 4     : 62      }
        memory        = { params.mode == 'exome' ? 15.GB : 246.GB  }
        time          = { params.mode == 'exome' ? 1.h   : 4.h     }
    }

    // ---------------------------------------------------------------------
    // bcftools stats — lightweight per-sample VCF stats for MultiQC
    // ---------------------------------------------------------------------
    withName: 'BCFTOOLS_STATS' {
        container     = "quay.io/biocontainers/bcftools:1.21--h8b25389_0"
        errorStrategy = { task.attempt <= 2 ? 'retry' : 'ignore' }
        cpus          = 2
        memory        = 7.GB
        time          = 1.h
    }

    // ---------------------------------------------------------------------
    // MultiQC summary report
    // ---------------------------------------------------------------------
    withName: 'MULTIQC_DV' {
        container     = "quay.io/biocontainers/multiqc:1.33--pyhdfd78af_0"
        errorStrategy = { task.attempt <= 2 ? 'retry' : 'terminate' }
        cpus          = { 2 * task.attempt }
        memory        = { 7.GB * task.attempt }
        time          = 2.h
    }
}

// ============================================================================
// LOAD REPORTING CONFIGURATION
// ============================================================================
includeConfig './conf/reporting.config'
